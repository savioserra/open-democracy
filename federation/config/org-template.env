# Organization configuration for a new federation node.
# Copy this file to .env and edit before running bootstrap-node.sh.

# --- Organization identity ---

# Short machine-readable name (lowercase, no spaces). Used in container
# names, MSP IDs, and DNS entries.
ORG_NAME=my-org

# Human-readable display name.
ORG_DISPLAY="My Organization"

# MSP ID for Fabric (PascalCase by convention, must be unique in the network).
ORG_MSP_ID=MyOrgMSP

# Domain for this organization's certificates.
ORG_DOMAIN=myorg.od.example.com

# --- Scope hierarchy ---

# Root scope prefix for this organization. All participants in this org
# will have scope claims prefixed with this value.
# Examples:
#   Government:  GOV:CITY_PORTO_ALEGRE
#   Union:       UNION:TEACHERS_SP
#   Company:     CORP:ACME
#   Community:   COMMUNITY:NEIGHBORHOOD_A
SCOPE_PREFIX=ORG:MY_ORG

# --- Network connection ---

# Orderer address(es) to connect to. Comma-separated for multiple orderers.
ORDERER_ADDRESSES=orderer1.od.example.com:7050,orderer2.od.example.com:7050

# Channel to join (the main governance channel).
CHANNEL_NAME=governance

# Chaincode name (should match what the founding consortium deployed).
CHAINCODE_NAME=bill

# --- Peer configuration ---

# Number of peers to run (1 is sufficient for most orgs, 2 for redundancy).
PEER_COUNT=1

# Peer listen port (first peer; subsequent peers increment by 1000).
PEER_PORT=7051

# --- Certificate Authority ---

# CA admin credentials (change these!).
CA_ADMIN_USER=admin
CA_ADMIN_PASS=adminpw

# CA server port.
CA_PORT=7054

# --- Gateway (dashboard + REST API) ---

# Gateway listen port.
GATEWAY_PORT=8080

# Default user for the dashboard.
GATEWAY_DEFAULT_USER=admin

# --- Optional: CouchDB for rich queries ---

# Set to "true" to enable CouchDB as the state database (enables rich
# JSON queries on the ledger). Set to "false" for LevelDB (simpler,
# faster for key-based lookups).
USE_COUCHDB=false
COUCHDB_PORT=5984
COUCHDB_USER=admin
COUCHDB_PASS=adminpw
